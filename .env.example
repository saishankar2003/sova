# ═══════════════════════════════════════════════════════
# NextX — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# === App ===
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# === MongoDB ===
MONGODB_URI=mongodb://localhost:27017/nextx
MONGODB_DB_NAME=nextx

# === Redis ===
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_ACCESS_SECRET=your-super-secret-access-key-change-me-in-production-32chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me-in-production-32chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Firebase ===
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_KEY=

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# === n8n ===
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_TIMEOUT_MS=30000

# === Email (Resend) ===
RESEND_API_KEY=
EMAIL_FROM=NextX <noreply@nextx.co.uk>

# === Sentry ===
SENTRY_DSN=

# === Admin ===
ADMIN_INITIAL_EMAIL=admin@nextx.co.uk
ADMIN_INITIAL_PASSWORD=changeme123
