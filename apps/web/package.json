{
  "name": "@nextx/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @nextx/shared build && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
